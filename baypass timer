// ==UserScript==
// @name         Universal Timer Bypass
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Skip countdowns and reveal direct download links
// @author       XLS
// @match        *://*/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';
    console.log('Scanner active...');

    // الهجوم الأول: البحث عن العداد نفسه وتخطيه للأمام
    setInterval(() => {
        // ابحث عن أي عنصر يحوي أرقاماً ويبدو كأنه عداد
        const timers = document.querySelectorAll('[id*="timer"], [class*="timer"], [id*="countdown"], [class*="countdown"]');
        timers.forEach(el => {
            // إذا كان العداد يظهر (غير مخفي)
            if (el.offsetParent !== null) {
                const num = parseInt(el.innerText);
                // إذا كان رقماً، فهذا هو الهدف
                if (!isNaN(num)) {
                    console.log('Timer found, skipping...');
                    // تخمين الذهاب مباشرة إلى 0
                    el.innerText = '0';
                    // الضغط على أي زر تحميل قريب
                    const btn = document.querySelector('a[href*="download"], button, .btn, [class*="download"]');
                    if (btn) {
                        btn.click();
                    }
                }
            }
        });
    }, 1000); // يتحقق كل ثانية

    // الهجوم الثاني: إجبار الروابط المخفية على الظهور مباشرة
    const reveal = () => {
        // قتل كل الروابط المخفية وجعلها مرئية
        const links = document.querySelectorAll('a[href*="download"], a[href*="file"], a[href*="get"], a[href*="link"]');
        links.forEach(link => {
            if (link.offsetParent === null) {
                link.style.display = 'block';
                link.style.visibility = 'visible';
                link.style.opacity = '1';
                link.style.pointerEvents = 'auto';
                link.style.zIndex = '9999';
                console.log('Link revealed: ' + link.href);
            }
        });
    };
    setTimeout(reveal, 500);
    setInterval(reveal, 2000);

})();
